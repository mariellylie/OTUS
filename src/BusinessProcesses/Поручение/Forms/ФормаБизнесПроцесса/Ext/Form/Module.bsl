
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Структура = ЭтаФорма.Параметры.ЗначенияЗаполнения;
	
	Если Структура.Свойство("ЗаполненоИзДанныхЗаполнения") Тогда
		Объект.ЗаполненоИзДанныхЗаполнения = Истина;
		Объект.ВедущаяЗадача = Структура.ВедущаяЗадача;
	КонецЕсли;
	
КонецПроцедуры
