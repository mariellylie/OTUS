&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("ВедущаяЗадача", ПараметрКоманды);
	ЗначенияЗаполнения.Вставить("ЗаполненоИзДанныхЗаполнения", Истина);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	
	ОткрытьФорму("БизнесПроцесс.Поручение.Форма.ФормаБизнесПроцесса", ПараметрыФормы);
	
КонецПроцедуры
